<Configs>

<append xpath="/Sounds">

<SoundDataNode name="lawnmower_start"> <AudioSource name="Sounds/AudioSource_Vehicle"/>
	<AudioClip ClipName="#@modfolder:Resources/LawnMower_Z.unity3d?LawnMowerStart"/>
	<LocalCrouchVolumeScale value="1.0"/> 
	<CrouchNoiseScale value="0.5"/> 
	<NoiseScale value="1"/> 
	<MaxVoices value="10"/> 
	<MaxRepeatRate value="0.01"/> 
</SoundDataNode>

<SoundDataNode name="lawnmower_idle_lp"> <AudioSource name="Sounds/AudioSource_Vehicle"/>
	<AudioClip ClipName="#@modfolder:Resources/LawnMower_Z.unity3d?LawnMowerIdle" Loop="True"/>
	<LocalCrouchVolumeScale value="1.0"/> <CrouchNoiseScale value="0.5"/> 
	<NoiseScale value="1"/> 
	<MaxVoices value="10"/> 
	<MaxRepeatRate value="0.01"/> 
</SoundDataNode>

<SoundDataNode name="lawnmower_max_speed_lp"> <AudioSource name="Sounds/AudioSource_Vehicle"/>
	<AudioClip ClipName="#@modfolder:Resources/LawnMower_Z.unity3d?LawnMowerDrive" Loop="True"/>
	<LocalCrouchVolumeScale value="1.0"/> <CrouchNoiseScale value="0.5"/> <NoiseScale value="1"/> 
	<MaxVoices value="10"/> 
	<MaxRepeatRate value="0.01"/> 
</SoundDataNode>

</append>
</Configs>	