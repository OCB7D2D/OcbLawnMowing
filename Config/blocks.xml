<configs patcher-version="2">

	<append xpath="/blocks">

		<block name="cntCarLawnMower0Master">

			<property name="CreativeMode" value="None"/>
			<property name="Material" value="Mmetal"/>
			<property name="Class" value="CarExplodeLoot"/>
			<property name="MaxDamage" value="750"/>
			<!-- cars explode when destroyed by a tool without harvest settings -->
			<property name="CustomIcon" value="vehicleLawnMowerPlaceable"/>
			<property name="ItemTypeIcon" value="explosion"/>
			<property name="LootList" value="mowers"/>
			<property name="Shape" value="ModelEntity"/>
			<property name="IsTerrainDecoration" value="true"/>
			<property name="Model" value="#@modfolder:Resources/LawnMowers.unity3d?LawnMowerDefect"/>
			<property name="Place" value="TowardsPlacer"/>
			<property name="ModelOffset" value="0,0,0.25"/>
			<property name="TintColor" value="B0B0B0"/>
			<property name="DisplayType" value="blockMulti"/>
			<property name="MultiBlockDim" value="1,1,3"/>
			<property name="ImposterDontBlock" value="true"/>
			<property name="ShowModelOnFall" value="false"/>
			<property name="PassThroughDamage" value="true"/>
			<!-- <property name="ParticleOnDeath" value="car_destruction_dmg1"/> -->
			<drop event="Harvest" name="terrStone" count="0" tool_category="Disassemble"/>
			<drop event="Harvest" name="resourceHeadlight" count="1" prob="0.2" tag="salvageHarvest"/>
			<drop event="Harvest" name="resourceMechanicalParts" count="1,2" prob="0.1" tag="salvageHarvest"/>
			<drop event="Harvest" name="resourceElectricParts" count="0,4" prob="0.1" tag="salvageHarvest"/>
			<drop event="Harvest" name="resourceLeather" count="1,3" prob="0.2" tag="salvageHarvest"/>
			<drop event="Harvest" name="resourceScrapIron" count="10,20" tag="allHarvest"/>
			<drop event="Destroy" count="0"/>
			<!-- <drop event="Fall" name="cntCar03SedanDamage1Master" count="1" prob="1.0" stick_chance="1"/> -->
			<!-- <property name="DowngradeBlock" value="cntCar03SedanDamage1Master"/> -->
			<property name="BigDecorationRadius" value="5"/>
			<property name="CanDecorateOnSlopes" value="false"/>
			<property class="Explosion">
				<property name="ParticleIndex" value="4"/>
				<!-- which prefab/particle is used -->
				<property name="RadiusBlocks" value="3.5"/>
				<!-- damage radius for blocks -->
				<property name="BlockDamage" value="500"/>
				<!-- damage for blocks in the center of the explosion -->

				<property name="RadiusEntities" value="5"/>
				<!-- damage radius for entities -->
				<property name="EntityDamage" value="250"/>
				<!-- damage for entities in the center of the explosion -->
			</property>
			<property name="PlacementDistance" value="6"/>
			<property name="FilterTags" value="MC_building,SC_automotive"/>
			<drop event="Harvest" name="modMeleeClubMetalChain" count="1" prob="0.015" tag="salvageHarvest"/>
			<drop event="Harvest" name="modMeleeTemperedBlade" count="1" prob="0.015" tag="salvageHarvest"/>
			<drop event="Harvest" name="meleeToolAxeT3ChainsawParts" count="1" prob="0.05" tag="salvageHarvest"/>
			<drop event="Harvest" name="gunBotRoboticsParts" count="1" prob="0.025" tag="salvageHarvest"/>
			<drop event="Harvest" name="modVehicleMowerGrassCollector" count="1" prob="0.035" tag="salvageHarvest"/>
			<drop event="Harvest" name="modVehicleMowerPlantCollector" count="1" prob="0.015" tag="salvageHarvest"/>
			<drop event="Harvest" name="modVehicleMowerCropsCollector" count="1" prob="0.008" tag="salvageHarvest"/>
			<drop event="Harvest" name="modVehicleMowerCropsProtector" count="1" prob="0.01" tag="salvageHarvest"/>
			<drop event="Harvest" name="modVehicleMowerCropsReseeder" count="1" prob="0.004" tag="salvageHarvest"/>
		</block>


		<!-- Blue -->
		<block name="cntCarLawnMower0v01">
			<property name="Extends" value="cntCarLawnMower0Master"/>
			<property name="CreativeMode" value="Player"/>
			<property name="CustomIconTint" value="FCA93F"/>
			<property name="TintColor" value="FCA93F"/>
		</block>

		<!-- Yellow -->
		<block name="cntCarLawnMower0v02">
			<property name="Extends" value="cntCarLawnMower0Master"/>
			<property name="CreativeMode" value="Player"/>
			<property name="CustomIconTint" value="00B903"/>
			<property name="TintColor" value="00B903"/>
		</block>

		<!-- Mixed -->
		<block name="cntCarLawnMower0v04">
			<property name="Extends" value="cntCarLawnMower0Master"/>
			<property name="CreativeMode" value="Player"/>
		</block>

		<!-- Red -->
		<block name="cntCarLawnMower0v05">
			<property name="Extends" value="cntCarLawnMower0Master"/>
			<property name="CreativeMode" value="Player"/>
			<property name="CustomIconTint" value="00B9C3"/>
			<property name="TintColor" value="00B9C3"/>
		</block>

		<!-- Green -->
		<block name="cntCarLawnMower0v06">
			<property name="Extends" value="cntCarLawnMower0Master"/>
			<property name="CreativeMode" value="Player"/>
			<property name="CustomIconTint" value="3B593B"/>
			<property name="TintColor" value="3B593B"/>
		</block>

		<!-- Grey -->
		<block name="cntCarLawnMower0v07">
			<property name="Extends" value="cntCarLawnMower0Master"/>
			<property name="CreativeMode" value="Player"/>
			<property name="CustomIconTint" value="5E5E5E"/>
			<property name="TintColor" value="5E5E5E"/>
		</block>

	</append>

	<include path="blocks.a20.xml"/>

</configs>